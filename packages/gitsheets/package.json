{
  "name": "gitsheets",
  "version": "0.0.0-dev",
  "description": "A git-backed document store for low-volume, high-touch, human-scale data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "gitsheets": "./bin/gitsheets",
    "git-sheet": "./bin/gitsheets"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JarvusInnovations/gitsheets.git"
  },
  "homepage": "https://github.com/JarvusInnovations/gitsheets#readme",
  "bugs": {
    "url": "https://github.com/JarvusInnovations/gitsheets/issues"
  },
  "license": "Apache-2.0",
  "author": "Jarvus Innovations",
  "dependencies": {
    "@gitsheets/core-napi": "^0.0.0",
    "@hologit/holo-tree": "^0.3.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "rfc6902": "^5.2.0",
    "sort-keys": "^6.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/yargs": "^17.0.35",
    "tmp": "^0.2.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
