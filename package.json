{
  "name": "gitsheets",
  "version": "1.0.0-substrate.0",
  "description": "A git-backed document store for low-volume, high-touch, human-scale data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "gitsheets": "./bin/gitsheets",
    "git-sheet": "./bin/gitsheets"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JarvusInnovations/gitsheets.git"
  },
  "homepage": "https://github.com/JarvusInnovations/gitsheets#readme",
  "bugs": {
    "url": "https://github.com/JarvusInnovations/gitsheets/issues"
  },
  "license": "Apache-2.0",
  "author": "Jarvus Innovations",
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "hologit": "^0.49.1",
    "sort-keys": "^6.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/yargs": "^17.0.35",
    "tmp": "^0.2.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
